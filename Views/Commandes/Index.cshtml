@model IEnumerable<Readify.Models.Commande>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DateCommande)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Statut)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MontantTotal)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Utilisateur)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DateCommande)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Statut)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MontantTotal)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Utilisateur.UtilisateurID)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.CommandeID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.CommandeID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.CommandeID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

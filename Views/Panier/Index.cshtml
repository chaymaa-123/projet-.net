                            <path d="M58.4918 10.475C59.08 10.475 59.5568 9.9965 59.5568 9.40625C59.5568 8.816 59.08 8.3375 58.4918 8.3375C57.9036 8.3375 57.4268 8.816 57.4268 9.40625C57.4268 9.9965 57.9036 10.475 58.4918 10.475ZM58.4918 11.1875C57.5115 11.1875 56.7168 10.39 56.7168 9.40625C56.7168 8.42249 57.5115 7.625 58.4918 7.625C59.4721 7.625 60.2668 8.42249 60.2668 9.40625C60.2668 10.39 59.4721 11.1875 58.4918 11.1875Z" fill="#999999"></path>

                        </svg>
                    </div>
                </div>

                <p class="text-muted mb-4">Votre panier est vide.</p>
                <a asp-controller="Livres" asp-action="Affichage" class="btn btn-outline-dark rounded-pill px-4 mb-4">Parcourir les livres</a>

                <div class="trust-badges-wrapper">
                    <div class="trust-item">
                        <img src="https://aimg.kwcdn.com/upload_aimg/temu/044bc6f4-c0d3-4d82-aa12-ca1ea0089ead.png.slim.png?imageView2/2/w/800/q/70/format/webp" class="trust-icon" alt="Paiement Sécurisé" />
                        <span class="trust-text">Paiement Sécurisé</span>
                    </div>
                    <div class="trust-item">
                        <img src="https://aimg.kwcdn.com/upload_aimg/temu/5ca28ce8-6913-4647-ab74-17b4e8a2977f.png.slim.png?imageView2/2/w/800/q/70/format/webp" class="trust-icon" alt="Données Protégées" />
                        <span class="trust-text">Protection des données</span>
                    </div>
                    <div class="trust-item">
                        <img src="https://aimg.kwcdn.com/upload_aimg/temu/9801ecbd-bdef-48e6-9a24-0a41d0340898.png?imageView2/2/w/800/q/70/format/webp" class="trust-icon" alt="Garantie Readify" />
                        <span class="trust-text">Garantie Readify</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.js-qty').click(function () {
                var id = $(this).data('id');
                var change = $(this).data('change');

                $.post('/Panier/UpdateQuantiteAjax', { id: id, changement: change }, function (data) {
                    if (data.success) {
                        if (data.nouvelleQty <= 0) {
                            $('#row-' + id).fadeOut();
                        } else {
                            $('#qty-' + id).text(data.nouvelleQty);
                            $('#sub-' + id).text(data.nouveauSousTotal);
                        }
                        $('#total-gen').text(data.nouveauTotalGeneral);

                        // Petit rechargement pour mettre à jour la logique "Panier Vide" si on enlève tout
                        if (data.nouvelleQty <= 0 && data.nouveauTotalGeneral == "0.00") {
                            location.reload();
                        }
                    }
                });
            });
        });
    </script>
}
@model IEnumerable<Readify.Models.Livre>

@{
    ViewData["Title"] = "Bibliothèque Readify";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">

<style>
    :root {
        --accent-pink: #ff4da6;
        --dark-royal: #1a1a2e;
        --glass: rgba(255, 255, 255, 0.9);
        --card-w: 190px; /* Taille moyenne et sexy */
    }

    /* body { */
    /*     background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%); */
    /*     font-family: 'Outfit', sans-serif; */
    /*     color: var(--dark-royal); */
    /* } */

    /* --- TITRE LUXE --- */
    .header-section {
        text-align: center;
        margin: 60px 0 40px;
    }

    .readify-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.5rem;
        font-weight: 700;
        font-style: italic;
        background: linear-gradient(to right, #1a1a2e, #ff4da6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 10px;
    }

    /* --- TOOLBAR GLASSMORPHISM --- */
    .toolbar-container {
        background: var(--glass);
        backdrop-filter: blur(10px);
        padding: 12px 30px;
        border-radius: 100px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 0 auto 50px;
        max-width: 850px;
        border: 1px solid rgba(255,255,255,0.3);
    }

    .filter-select {
        border: none;
        background: none;
        font-weight: 600;
        color: var(--dark-royal);
        font-size: 1rem;
        cursor: pointer;
        outline: none;
    }

    /* --- GRILLE DE LIVRES --- */
    .book-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(var(--card-w), 1fr));
        gap: 35px;
        padding-bottom: 100px;
    }

    /* --- CARTE SEXY --- */
    .book-card {
        position: relative;
        aspect-ratio: 1 / 1.5;
        border-radius: 24px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-decoration: none;
    }

        .book-card:hover {
            transform: translateY(-15px) rotate(2deg);
            box-shadow: 0 30px 60px rgba(255, 77, 166, 0.2);
        }

    .book-cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .book-card:hover .book-cover {
        transform: scale(1.1);
    }

    /* OVERLAY AVEC TEXTE MOYEN ET LISIBLE */
    .book-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 20px;
        transition: 0.3s;
    }

    .book-title {
        color: #fff;
        font-size: 1.1rem; /* Taille moyenne idéale */
        font-weight: 600;
        margin-bottom: 5px;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .book-price {
        color: #ffdd59;
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: 0.5px;
    }

    /* BADGE GENRE CHIC */
    .badge-genre {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(5px);
        color: var(--dark-royal);
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
</style>

<div class="container" style="max-width: 1200px;">
    <div class="header-section">
        <h1 class="readify-title">Bibliothèque</h1>
        <p style="letter-spacing: 5px; color: #a4b0be; font-weight: 600; font-size: 0.8rem;">CURATED COLLECTIONS</p>
    </div>

    <div class="toolbar-container">
        <div style="font-weight: 800; font-size: 0.9rem; color: var(--accent-pink);">
            <i class="fas fa-heart me-2"></i> @Model.Count() HISTOIRES
        </div>

        <form asp-controller="Livres" asp-action="Affichage" method="get">
            <div class="d-flex align-items-center bg-light px-3 py-1 rounded-pill">
                <i class="fas fa-filter me-2 text-muted" style="font-size:0.8rem;"></i>
                <select name="genreId" class="filter-select" onchange="this.form.submit()" asp-items="@(ViewData["GenresPourFiltre"] as SelectList)">
                    <option value="">Tous les genres</option>
                </select>
            </div>
        </form>
    </div>

    <div class="book-grid">
        @foreach (var item in Model)
        {
            <a asp-action="Details" asp-route-id="@item.LivreId" class="book-card">
                @if (item.Genre != null)
                {
                    <div class="badge-genre">@item.Genre.NomGenre</div>
                }

                <img src="/img/@(item.ImageUrl ?? "default.jpg")" class="book-cover" alt="@item.Titre" />

                <div class="book-overlay">
                    <h3 class="book-title">@item.Titre</h3>
                    <div class="book-price">
                        @* Correction CS1061 : Utilisation directe car Prix est decimal *@
                        @item.Prix.ToString("N2") DHS

                    </div>
                </div>
            </a>
        }
    </div>
</div>
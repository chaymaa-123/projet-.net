@model Readify.Models.Livre

@{
    ViewData["Title"] = "Modifier l'histoire";
}

<h1>Modifier</h1>

<h4>Livre</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="LivreId" />

            <input type="hidden" asp-for="ImageUrl" />

            <div class="form-group mb-3">
                <label asp-for="Titre" class="control-label"></label>
                <input asp-for="Titre" class="form-control" />
                <span asp-validation-for="Titre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Resume" class="control-label"></label>
                <textarea asp-for="Resume" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Resume" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="Prix" class="control-label"></label>
                    <input asp-for="Prix" class="form-control" />
                    <span asp-validation-for="Prix" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="DatePublication" class="control-label"></label>
                    <input asp-for="DatePublication" type="date" class="form-control" />
                    <span asp-validation-for="DatePublication" class="text-danger"></span>
                </div>
            </div>

            <div class="form-check mb-3">
                <input asp-for="EstPubliee" class="form-check-input" />
                <label asp-for="EstPubliee" class="form-check-label"></label>
            </div>

            <div class="card mb-3 p-3 bg-light">
                <label asp-for="ImageFile" class="control-label fw-bold">Changer la photo</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-2">
                        <small>Photo actuelle :</small><br />
                        <img src="~/img/@Model.ImageUrl" style="width:100px; border-radius:5px;" />
                    </div>
                }
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="GenreID" class="control-label">Genre</label>
                <select asp-for="GenreID" class="form-control" asp-items="ViewBag.GenreID"></select>
                <span asp-validation-for="GenreID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-success">Enregistrer les modifications</button>
                <a asp-action="Affichage" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
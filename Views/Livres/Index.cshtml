@model IEnumerable<Readify.Models.Livre>

@{

	ViewData["Title"] = "Index";

}



<h1>Index</h1>




<p>

	<a asp-action="Create">Create New</a>

</p>

<table class="table">

	<thead>

		<tr>

			<th>

				@Html.DisplayNameFor(model => model.Titre)

			</th>

			<th>

				@Html.DisplayNameFor(model => model.Resume)

			</th>

			<th>

				@Html.DisplayNameFor(model => model.Prix)

			</th>

			<th>

				@Html.DisplayNameFor(model => model.DatePublication)

			</th>

			<th>

				@Html.DisplayNameFor(model => model.EstPubliee)

			</th>


			<th>

				@Html.DisplayNameFor(model => model.Genre)

			</th>

			<th></th>

		</tr>

	</thead>

	<tbody>

		@foreach (var item in Model)
		{

			<tr>

				<td>

					@Html.DisplayFor(modelItem => item.Titre)

				</td>

				<td>

					@Html.DisplayFor(modelItem => item.Resume)

				</td>

				<td>

					@Html.DisplayFor(modelItem => item.Prix)

				</td>

				<td>

					@Html.DisplayFor(modelItem => item.DatePublication)

				</td>

				<td>

					@Html.DisplayFor(modelItem => item.EstPubliee)

				</td>


				<td>

					@Html.DisplayFor(modelItem => item.Genre.GenreID)

				</td>

				<td>

					<a asp-action="Edit" asp-route-id="@item.LivreId">Edit</a> |

					<a asp-action="Details" asp-route-id="@item.LivreId">Details</a> |

					<a asp-action="Delete" asp-route-id="@item.LivreId">Delete</a>

				</td>

			</tr>

		}

	</tbody>

</table>


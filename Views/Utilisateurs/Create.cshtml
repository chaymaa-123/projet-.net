@model Readify.Models.Utilisateur

@{
    ViewData["Title"] = "Ajouter un Administrateur/Membre";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-dark text-white p-4">
            <h3 class="mb-0">Gestion des Comptes Admin</h3>
        </div>
        <div class="card-body p-5">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="NomUtilisateur" class="form-label fw-bold">Nom d'utilisateur</label>
                        <input asp-for="NomUtilisateur" class="form-control form-control-lg" placeholder="Ex: Admin_Readify" />
                        <span asp-validation-for="NomUtilisateur" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold">Adresse Email</label>
                        <input asp-for="Email" class="form-control form-control-lg" placeholder="admin@readify.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="MotDePasseHash" class="form-label fw-bold">Mot de passe</label>
                        <input asp-for="MotDePasseHash" type="password" class="form-control form-control-lg" />
                        <span asp-validation-for="MotDePasseHash" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="RoleID" class="form-label fw-bold">Type de compte (Rôle)</label>
                        <select asp-for="RoleID" class="form-select form-select-lg" asp-items="ViewBag.RoleID">
                            <option value="">-- Sélectionner le privilège --</option>
                        </select>
                        <span asp-validation-for="RoleID" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-5">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Annuler</a>
                    <button type="submit" class="btn btn-dark px-5 font-weight-bold">Créer le compte</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}